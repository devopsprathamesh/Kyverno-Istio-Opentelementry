#!/usr/bin/env bash
# Pinned component versions for this module. Sourced by scripts/lib/common.sh.
# Research date: 2026-07-24. Sources: GitHub Releases API, official Helm
# chart index.yaml files, official docs — see ../../docs/VERSIONS.md
# "Phase 5 addendum" for full citations and reasoning.
# No ':latest' tags anywhere in this module.

# --- OpenTelemetry Collector -----------------------------------------------
OTEL_COLLECTOR_CONTRIB_IMAGE="otel/opentelemetry-collector-contrib"
OTEL_COLLECTOR_CONTRIB_VERSION="0.157.0"
OTEL_COLLECTOR_HELM_CHART_VERSION="0.165.0"
# Chart's own appVersion (0.156.0) trails the contrib image tag above by one
# release; install.sh overrides image.tag explicitly rather than trusting
# the chart default — see docs/DECISIONS.md ADR-029.

# --- OpenTelemetry Operator --------------------------------------------------
OTEL_OPERATOR_IMAGE_VERSION="v0.156.0"
OTEL_OPERATOR_HELM_CHART_VERSION="0.120.0"
# cert-manager is NOT installed by default — the Operator chart's
# admissionWebhooks.autoGenerateCert path is used instead. See
# install/cert-manager/README.md and docs/DECISIONS.md ADR-026.
CERT_MANAGER_VERSION="v1.21.0"

# --- Helm chart repositories -------------------------------------------------
OTEL_HELM_REPO="https://open-telemetry.github.io/opentelemetry-helm-charts"
OTEL_HELM_REPO_NAME="open-telemetry"
PROMETHEUS_COMMUNITY_HELM_REPO="https://prometheus-community.github.io/helm-charts"
PROMETHEUS_COMMUNITY_HELM_REPO_NAME="prometheus-community"
# Grafana and Loki charts moved off the legacy grafana.github.io/helm-charts
# index (now stale/frozen for these charts) to a new community-maintained
# index — see docs/VERSIONS.md Phase 5 addendum. Do not use the legacy repo.
GRAFANA_HELM_REPO="https://grafana-community.github.io/helm-charts"
GRAFANA_HELM_REPO_NAME="grafana-community"
JAEGER_HELM_REPO="https://jaegertracing.github.io/helm-charts"
JAEGER_HELM_REPO_NAME="jaegertracing"

# --- Prometheus stack (kube-prometheus-stack) --------------------------------
KUBE_PROMETHEUS_STACK_CHART_VERSION="87.19.0"
PROMETHEUS_APP_VERSION="v3.13.1"
PROMETHEUS_OPERATOR_VERSION="v0.92.1"
ALERTMANAGER_VERSION="v0.33.1"
KUBE_STATE_METRICS_CHART_VERSION="8.0.0"
KUBE_STATE_METRICS_APP_VERSION="v2.19.1"
NODE_EXPORTER_CHART_VERSION="4.56.1"
NODE_EXPORTER_APP_VERSION="v1.12.1"
# Exemplar storage is feature-flagged, not default-on in Prometheus 3.x —
# install/prometheus/values-*.yaml sets enableFeatures: [exemplar-storage].

# --- Grafana ------------------------------------------------------------------
GRAFANA_APP_VERSION="v13.1.1"
GRAFANA_HELM_CHART_VERSION="12.8.0"

# --- Jaeger ---------------------------------------------------------------
JAEGER_APP_VERSION="2.20.0"
JAEGER_HELM_CHART_VERSION="4.11.1"
# Chart's own appVersion (2.19.0) trails the app version above by one
# release; install.sh overrides image.tag explicitly. The Jaeger Operator
# is upstream-deprecated ("only works with retired Jaeger v1") and is
# never used by this module — see docs/DECISIONS.md ADR-027.
JAEGER_OTLP_GRPC_PORT="4317"
JAEGER_OTLP_HTTP_PORT="4318"

# --- Loki -----------------------------------------------------------------
LOKI_HELM_CHART_VERSION="18.5.3"
LOKI_APP_VERSION="3.7.4"
LOKI_DEPLOYMENT_MODE="Monolithic"
# Current chart terminology: Monolithic (was SingleBinary), SimpleScalable
# (deprecated, removal targeted Loki 4.0), Distributed. Native OTLP ingest
# at POST /otlp/v1/logs — the Collector otlphttp exporter's `endpoint` must
# be set to http://<loki-svc>:3100/otlp (no /v1/logs suffix, the exporter
# appends it itself). The Collector Contrib `loki` exporter component was
# REMOVED (not merely deprecated) around contrib v0.130.0 — never reference
# it; otlphttp is the only supported path. See docs/DECISIONS.md ADR-029
# is about Collector deployment; this Loki-OTLP note is ADR-007/008
# (already recorded) plus docs/06-logs.md for the full explanation.
LOKI_OTLP_PORT="3100"

# --- Kubernetes compatibility -----------------------------------------------
OBSERVABILITY_SUPPORTED_K8S_MIN="1.32"
OBSERVABILITY_SUPPORTED_K8S_MAX="1.36"

# --- Demo application SDKs --------------------------------------------------
DEMO_PYTHON_OTEL_SDK_VERSION="1.44.0"
DEMO_NODE_OTEL_SDK_NODE_VERSION="0.221.0"
DEMO_NODE_BASE_IMAGE="node:22.17.0-slim"
DEMO_PYTHON_BASE_IMAGE="python:3.13.5-slim"
DEMO_FRONTEND_IMAGE="otel-demo/frontend"
DEMO_FRONTEND_IMAGE_TAG="1.0.0"
DEMO_ORDER_SERVICE_IMAGE="otel-demo/order-service"
DEMO_ORDER_SERVICE_IMAGE_TAG="1.0.0"
DEMO_INVENTORY_SERVICE_IMAGE="otel-demo/inventory-service"
DEMO_INVENTORY_SERVICE_IMAGE_TAG="1.0.0"
DEMO_PAYMENT_SERVICE_IMAGE="otel-demo/payment-service"
DEMO_PAYMENT_SERVICE_IMAGE_TAG="1.0.0"
DEMO_LOAD_GENERATOR_IMAGE="otel-demo/load-generator"
DEMO_LOAD_GENERATOR_IMAGE_TAG="1.0.0"
# No registry is used, public or private — build-demo-images.sh builds
# locally and imports images directly into each cluster node's containerd.
# See docs/DECISIONS.md ADR-030.
