#!/usr/bin/env bash
# Retention/storage-size settings, split by LAB_PROFILE. install/*/values-
# {minimum,recommended}.yaml read the matching pair directly rather than
# sourcing this file (Helm values can't source bash) — this file is the
# single documented source of truth those two value-file pairs must stay
# consistent with; scripts/lib/observability.sh's profile-consistency check
# also greps against these values. See docs/19-cost-optimization.md.

# --- Prometheus (kube-prometheus-stack) -------------------------------------
PROMETHEUS_RETENTION_MINIMUM="6h"
PROMETHEUS_RETENTION_RECOMMENDED="24h"
PROMETHEUS_PVC_SIZE_MINIMUM="4Gi"
PROMETHEUS_PVC_SIZE_RECOMMENDED="10Gi"

# --- Loki --------------------------------------------------------------------
LOKI_RETENTION_MINIMUM="24h"
LOKI_RETENTION_RECOMMENDED="72h"
LOKI_PVC_SIZE_MINIMUM="4Gi"
LOKI_PVC_SIZE_RECOMMENDED="10Gi"

# --- Jaeger (in-memory or badger, see install/jaeger/values-*.yaml) --------
JAEGER_MAX_TRACES_MINIMUM=25000
JAEGER_MAX_TRACES_RECOMMENDED=100000
JAEGER_PVC_SIZE_RECOMMENDED="5Gi"
# minimum profile uses Jaeger's in-memory storage (no PVC at all) —
# explicitly non-persistent, documented in docs/14-loki-architecture.md's
# sibling doc docs/13-jaeger-architecture.md and the lab README.

# --- Grafana ------------------------------------------------------------------
GRAFANA_PVC_SIZE_MINIMUM="1Gi"
GRAFANA_PVC_SIZE_RECOMMENDED="2Gi"
