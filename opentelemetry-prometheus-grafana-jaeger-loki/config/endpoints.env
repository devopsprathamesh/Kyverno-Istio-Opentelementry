#!/usr/bin/env bash
# Expected cluster identity (from ../../auto-setup-default-kube-env) and
# this module's internal service endpoints. verify-cluster.sh refuses to
# proceed if the live cluster doesn't match the values in this file.

EXPECTED_CLUSTER_NAME="devops-learning-lab"
EXPECTED_API_ENDPOINT="192.168.56.10"
EXPECTED_CONTROL_PLANE_NAME="otel-control-plane"
EXPECTED_WORKER1_NAME="otel-worker-1"
EXPECTED_WORKER2_NAME="otel-worker-2"

# --- In-cluster service DNS names and ports --------------------------------
# (namespace comes from config/namespaces.env; these are Service names only)
PROMETHEUS_SERVICE="kube-prometheus-stack-prometheus"
PROMETHEUS_PORT=9090
ALERTMANAGER_SERVICE="kube-prometheus-stack-alertmanager"
ALERTMANAGER_PORT=9093
GRAFANA_SERVICE="grafana"
GRAFANA_PORT=3000
JAEGER_QUERY_SERVICE="jaeger-query"
JAEGER_QUERY_PORT=16686
JAEGER_COLLECTOR_OTLP_GRPC_SERVICE="jaeger-collector"
LOKI_SERVICE="loki"
LOKI_PORT=3100

COLLECTOR_AGENT_OTLP_GRPC_PORT=4317
COLLECTOR_AGENT_OTLP_HTTP_PORT=4318
COLLECTOR_GATEWAY_SERVICE="otel-collector-gateway"
COLLECTOR_GATEWAY_OTLP_GRPC_PORT=4317
COLLECTOR_GATEWAY_OTLP_HTTP_PORT=4318
COLLECTOR_GATEWAY_PROMETHEUS_EXPORTER_PORT=8889
COLLECTOR_HEALTH_CHECK_PORT=13133
COLLECTOR_ZPAGES_PORT=55679
COLLECTOR_PPROF_PORT=1777
COLLECTOR_INTERNAL_METRICS_PORT=8888

# --- Demo application service ports (all HTTP) ------------------------------
DEMO_FRONTEND_PORT=3000
DEMO_ORDER_SERVICE_PORT=8000
DEMO_INVENTORY_SERVICE_PORT=8000
DEMO_PAYMENT_SERVICE_PORT=8000
