#!/usr/bin/env bash
# Namespace ownership for this module. Never kube-system. See
# ../docs/15-kubernetes-observability.md for the full rationale.

OBSERVABILITY_NAMESPACE="observability"    # Prometheus, Alertmanager, Grafana, Jaeger, Loki
OPENTELEMETRY_NAMESPACE="opentelemetry"    # Operator, Collector agent + gateway, Instrumentation resources
OTEL_DEMO_NAMESPACE="otel-demo"            # Demo microservices + load generator

# Namespaces this module owns and is therefore allowed to clean up /
# uninstall from. clean.sh/uninstall-all.sh refuse to touch anything
# outside this list.
OWNED_NAMESPACES="${OBSERVABILITY_NAMESPACE} ${OPENTELEMETRY_NAMESPACE} ${OTEL_DEMO_NAMESPACE}"

# Standard ownership label applied to every resource this module creates.
LAB_RESOURCE_LABEL_KEY="app.kubernetes.io/part-of"
LAB_RESOURCE_LABEL_VALUE="observability-learning-lab"
