#!/usr/bin/env bash
# Lab-wide tunables. Sourced by scripts/lib/common.sh.

VALID_LAB_PROFILES="minimum recommended"
DEFAULT_LAB_PROFILE="recommended"

# --- Timeouts ---------------------------------------------------------------
INSTALL_WAIT_TIMEOUT_SECONDS=300
POD_READY_TIMEOUT_SECONDS=180
HELM_TIMEOUT="10m"

# --- Resource labeling / temp namespace convention (mirrors istio/) --------
TEMP_NAMESPACE_PREFIX="otel-lab-tmp-"

# --- Load generation defaults (scripts/generate-load.sh) -------------------
LOAD_DEFAULT_REQUESTS=200
LOAD_DEFAULT_CONCURRENCY=10
LOAD_DEFAULT_DURATION_SECONDS=60

# --- Demo application controllable behavior (env vars read by the apps) ----
DEMO_DEFAULT_LATENCY_MS=0
DEMO_DEFAULT_FAILURE_PERCENT=0
DEMO_DEFAULT_TIMEOUT_MS=3000
DEMO_DEFAULT_RETRY_ATTEMPTS=2

# --- Sampling (labs/lab-15-sampling.md) -------------------------------------
SAMPLING_RATIO_DEFAULT=0.5
TAIL_SAMPLING_DECISION_WAIT_SECONDS=10
TAIL_SAMPLING_SLOW_TRACE_THRESHOLD_MS=500
TAIL_SAMPLING_PROBABILISTIC_PERCENT=15

# --- Statistical tolerance for sampling/load-distribution assertions -------
STATISTICAL_TOLERANCE_PERCENT=15

# --- Grafana lab-only credentials (never real, never committed elsewhere) --
# Actual runtime admin password is generated into .generated/ (git-ignored)
# by scripts/install-grafana.sh — this is only the documented lab-default
# fallback if LAB_PROFILE=minimum skips password generation.
GRAFANA_LAB_DEFAULT_USER="admin"

# --- Port-forward local ports (config/endpoints.env has the full table) ----
COLLECTOR_GATEWAY_OTLP_GRPC_LOCAL_PORT=14317
COLLECTOR_GATEWAY_OTLP_HTTP_LOCAL_PORT=14318
