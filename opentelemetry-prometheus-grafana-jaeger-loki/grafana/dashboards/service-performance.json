{
  "title": "Service Performance",
  "uid": "service-performance",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["observability-learning-lab", "application"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(http_server_duration_milliseconds_count, job)", "multi": true, "includeAll": true, "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Per-service request rate", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "job:http_requests:rate5m{job=~\"$service\"}", "legendFormat": "{{job}}"}]
    },
    {
      "id": 2, "title": "Per-service P95 latency", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "job:http_request_duration:p95_5m{job=~\"$service\"}", "legendFormat": "{{job}}"}],
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []}
    },
    {
      "id": 3, "title": "Per-service error rate", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "job:http_error_ratio:ratio5m{job=~\"$service\"}", "legendFormat": "{{job}}"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}
    },
    {
      "id": 4, "title": "Inventory check duration", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(order_processing_duration_bucket[5m])) by (le))", "legendFormat": "order_processing p95"}]
    },
    {
      "id": 5, "title": "Payment authorization failure rate (dependency call)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(payment_failures_total[5m])) / sum(rate(payment_authorizations_total[5m]))", "legendFormat": "decline ratio"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}
    }
  ]
}
