{
  "title": "Kubernetes Workload Overview",
  "uid": "k8s-workload-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["observability-learning-lab", "kubernetes"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace", "type": "custom", "query": "observability,opentelemetry,otel-demo",
        "multi": true, "includeAll": true, "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Pod CPU (cores)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\"}[5m])) by (pod)", "legendFormat": "{{pod}}"}]
    },
    {
      "id": 2, "title": "Pod memory (working set)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\"}) by (pod)", "legendFormat": "{{pod}}"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "id": 3, "title": "Container restarts (1h)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[1h])", "legendFormat": "{{pod}}/{{container}}"}]
    },
    {
      "id": 4, "title": "Pending pods", "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(kube_pod_status_phase{namespace=~\"$namespace\", phase=\"Pending\"})"}]
    },
    {
      "id": 5, "title": "Deployment availability", "type": "table",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"} / kube_deployment_spec_replicas{namespace=~\"$namespace\"}", "format": "table", "instant": true}]
    }
  ]
}
