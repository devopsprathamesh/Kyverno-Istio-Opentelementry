# Copy to .env and source (`set -a; source .env; set +a`) before running
# `make`/`kubectl` commands to override defaults without editing tracked
# files. .env is git-ignored (root .gitignore: ".env"); this .example
# file is the only one tracked.

# --- Profile selection ----------------------------------------------------
# LAB_PROFILE=minimum

# --- Kubeconfig -------------------------------------------------------
# Point at the base platform's exported kubeconfig (see
# ../auto-setup-default-kube-env/docs/INSTALLATION.md):
# export KUBECONFIG=/absolute/path/to/auto-setup-default-kube-env/.generated/kubeconfig

# --- Destructive uninstall opt-in ----------------------------------------
# Only set when you specifically intend to delete every Operator/
# Prometheus-Operator CRD cluster-wide (see scripts/uninstall-all.sh's
# warning) — leave unset/false for normal use.
# REMOVE_CRDS=true

# --- generate-load / inject-latency / inject-errors args ------------------
# make generate-load ARGS="200 10 60"      # requests concurrency duration_s
# make inject-latency ARGS="1500 apply"    # ms apply|revert
# make inject-errors ARGS="30 apply"       # percent apply|revert

# See examples/curl-commands.md for the full request-command reference and
# examples/query-examples.md for PromQL/LogQL/Jaeger-API examples.
