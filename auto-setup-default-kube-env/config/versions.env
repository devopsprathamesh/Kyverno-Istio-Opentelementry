#!/usr/bin/env bash
# Single source of truth for every pinned version used by this module's
# scripts. Every script sources this file rather than hardcoding a version.
# See ../../docs/VERSIONS.md for sources, compatibility notes, and the
# research date behind each pin. Never replace a value here with "latest".

# --- Guest VM base image -----------------------------------------------
VAGRANT_BOX_NAME="bento/ubuntu-24.04"
VAGRANT_BOX_VERSION="202510.26.0"

# --- Kubernetes -----------------------------------------------------------
KUBERNETES_VERSION="1.35.6"
KUBERNETES_MINOR="1.35"
# Debian/Ubuntu package version string for this Kubernetes release
# (pkgs.k8s.io publishes packages as <upstream-version>-<pkg-revision>).
KUBERNETES_PKG_VERSION="1.35.6-1.1"
KUBERNETES_APT_REPO="https://pkgs.k8s.io/core:/stable:/v${KUBERNETES_MINOR}/deb/"
KUBERNETES_APT_KEY="https://pkgs.k8s.io/core:/stable:/v${KUBERNETES_MINOR}/deb/Release.key"

# --- containerd -------------------------------------------------------
CONTAINERD_VERSION="2.3.3"

# --- Cilium / Hubble ----------------------------------------------------
CILIUM_CHART_VERSION="1.19.3"
CILIUM_CLI_VERSION="0.19.5"
CILIUM_HELM_REPO="https://helm.cilium.io/"

# --- Helm -----------------------------------------------------------------
HELM_VERSION="4.2.3"
# Documented fallback (see docs/VERSIONS.md "uncertain compatibility" list)
# if a chart proves incompatible with Helm v4. Not used by default.
HELM_FALLBACK_VERSION="3.21.3"

# --- Storage --------------------------------------------------------------
LOCAL_PATH_PROVISIONER_VERSION="0.0.26"
LOCAL_PATH_PROVISIONER_MANIFEST="https://raw.githubusercontent.com/rancher/local-path-provisioner/v${LOCAL_PATH_PROVISIONER_VERSION}/deploy/local-path-storage.yaml"

# --- crictl -----------------------------------------------------------
# crictl is versioned separately from containerd; pin the same minor line
# as the pinned Kubernetes release per upstream guidance.
CRICTL_VERSION="1.35.0"
