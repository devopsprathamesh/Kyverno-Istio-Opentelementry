#!/usr/bin/env bash
# Resource profiles for the three VMs. LAB_PROFILE selects one of these
# as the default; per-node environment variables (see .env.example and
# examples/profile-overrides.env.example) override individual values
# without editing this file or the Vagrantfile.
#
# See ../../docs/ARCHITECTURE.md "Resource planning" for the rationale
# and the host-RAM sizing these profiles target.

VALID_LAB_PROFILES="minimum recommended"
DEFAULT_LAB_PROFILE="recommended"

# --- minimum profile: ~16 GB host RAM ------------------------------------
MINIMUM_CP_CPUS=2
MINIMUM_CP_MEMORY=3072
MINIMUM_WORKER1_CPUS=2
MINIMUM_WORKER1_MEMORY=3072
MINIMUM_WORKER2_CPUS=2
MINIMUM_WORKER2_MEMORY=3072

# --- recommended profile: ~32 GB host RAM (default) ----------------------
RECOMMENDED_CP_CPUS=2
RECOMMENDED_CP_MEMORY=4096
RECOMMENDED_WORKER1_CPUS=4
RECOMMENDED_WORKER1_MEMORY=7168
RECOMMENDED_WORKER2_CPUS=4
RECOMMENDED_WORKER2_MEMORY=7168

# Total RAM committed per profile, used by check-prerequisites.sh to warn
# when available host RAM is below what the selected profile needs.
MINIMUM_PROFILE_TOTAL_MEMORY_MB=9216
RECOMMENDED_PROFILE_TOTAL_MEMORY_MB=18432
