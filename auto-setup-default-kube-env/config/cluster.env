#!/usr/bin/env bash
# Cluster-wide constants: names, addresses, CIDRs. Scripts and the
# Vagrantfile both source this file rather than repeating these values.

CLUSTER_NAME="devops-learning-lab"

# --- Node topology (see ../../docs/ARCHITECTURE.md §3) ------------------
CONTROL_PLANE_NAME="otel-control-plane"
CONTROL_PLANE_IP="192.168.56.10"

WORKER1_NAME="otel-worker-1"
WORKER1_IP="192.168.56.11"

WORKER2_NAME="otel-worker-2"
WORKER2_IP="192.168.56.12"

HOSTONLY_NETMASK="255.255.255.0"
HOSTONLY_SUBNET_CIDR="192.168.56.0/24"

# --- Kubernetes networking -------------------------------------------
# kubeadm's controlPlaneEndpoint: the single stable address every node and
# the host use to reach the API server.
CONTROL_PLANE_ENDPOINT="${CONTROL_PLANE_IP}:6443"

# kube-apiserver default; made explicit here rather than left implicit.
SERVICE_SUBNET="10.96.0.0/12"

# Deliberately no POD_SUBNET here: Cilium's default cluster-pool IPAM
# (10.0.0.0/8, per-node /24) manages pod IPs independently of kubeadm's
# --pod-network-cidr flag. See docs/DECISIONS.md ADR-011.
CILIUM_CLUSTER_POOL_CIDR="10.0.0.0/8"
CILIUM_CLUSTER_POOL_MASK_SIZE="24"

# --- Namespaces this module owns ---------------------------------------
# Cilium/Hubble are installed into kube-system by default (the standard,
# most widely documented Cilium install target) rather than a separate
# "cilium"/"hubble" namespace — see docs/CILIUM-HUBBLE.md.
CILIUM_NAMESPACE="kube-system"
STORAGE_NAMESPACE="local-path-storage"

# --- Storage --------------------------------------------------------------
STORAGE_CLASS_NAME="local-path"

# --- crictl runtime endpoint --------------------------------------------
CRI_SOCKET="unix:///run/containerd/containerd.sock"
