# Example: running a custom resource split instead of either stock
# profile, e.g. a host with 24GB RAM that wants more than 'minimum' but
# can't fit 'recommended'. Copy the lines you need into your own .env
# (see ../.env.example) — LAB_PROFILE still selects the base profile
# these values layer on top of; only the variables you set here differ
# from that profile's defaults.
#
# Usage:
#   set -a; source .env; set +a
#   make setup LAB_PROFILE=minimum

CP_CPUS=2
CP_MEMORY=3584

WORKER1_CPUS=3
WORKER1_MEMORY=5120

WORKER2_CPUS=3
WORKER2_MEMORY=5120

# Total for this example: 8 vCPU / ~13.5GB — between the minimum
# (~9GB) and recommended (~18GB) profile totals in config/profiles.env.
