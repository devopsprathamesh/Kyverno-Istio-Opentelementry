# Example: provisioning behind an enterprise HTTP(S) proxy.
#
# Copy the lines you need into your own .env (see ../.env.example).
# Never commit real proxy credentials — if your proxy needs auth, embed
# it in the URL only inside your local, git-ignored .env, never here.
#
# When these variables are set, scripts/guest/00-common.sh configures:
#   - apt: /etc/apt/apt.conf.d/95proxy
# and 03-install-containerd.sh / 04-install-kubernetes.sh inherit the
# same proxy for their own package-repository fetches (apt uses the
# same apt.conf.d drop-in). NO_PROXY is always extended (not replaced)
# with localhost/127.0.0.1/all three node IPs/the service CIDR/the
# Cilium pod CIDR/.svc/.cluster.local, so in-cluster and node-to-node
# traffic never gets routed through the proxy.
#
# If HTTP_PROXY/HTTPS_PROXY are left unset (the default), no proxy
# configuration is written anywhere by this module.

HTTP_PROXY=http://proxy.example.internal:3128
HTTPS_PROXY=http://proxy.example.internal:3128
NO_PROXY=localhost,127.0.0.1,.example.internal

# Lowercase forms are also honored if your tooling expects them instead:
# http_proxy=http://proxy.example.internal:3128
# https_proxy=http://proxy.example.internal:3128
# no_proxy=localhost,127.0.0.1,.example.internal
