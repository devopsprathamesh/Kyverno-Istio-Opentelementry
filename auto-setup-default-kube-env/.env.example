# Copy this file to .env and source it (`set -a; source .env; set +a`)
# before running `make`/`vagrant` commands to override defaults without
# editing tracked files. .env itself is git-ignored (root .gitignore:
# ".env"); this .example file is the only one tracked.

# --- Profile selection ----------------------------------------------------
# LAB_PROFILE=minimum

# --- GUI mode ---------------------------------------------------------
# Show the VirtualBox GUI console for each VM instead of running headless.
# VAGRANT_GUI=true

# --- Per-node resource overrides -----------------------------------------
# Override individual node CPU/RAM without editing config/profiles.env or
# the Vagrantfile. See examples/profile-overrides.env.example for the
# full set of override variable names.
# CP_CPUS=2
# CP_MEMORY=4096
# WORKER1_CPUS=4
# WORKER1_MEMORY=7168
# WORKER2_CPUS=4
# WORKER2_MEMORY=7168

# --- Enterprise proxy support ----------------------------------------
# Only set these if your network requires a proxy for outbound HTTP(S).
# When unset, no proxy configuration is written anywhere by this module.
# See examples/proxy.env.example for the full explanation.
# HTTP_PROXY=http://proxy.example.internal:3128
# HTTPS_PROXY=http://proxy.example.internal:3128
# NO_PROXY=localhost,127.0.0.1

# --- Cilium Hubble UI -------------------------------------------------
# Hubble UI has a small resource footprint (~50m CPU / 64Mi mem) and is
# enabled by default. Disable it on very constrained hosts:
# HUBBLE_UI_ENABLED=false
