#!/usr/bin/env bash
# General lab behavior settings — timeouts, revision naming, and
# defaults referenced by the Makefile and scripts/*.sh.

VALID_LAB_PROFILES="minimum recommended"
DEFAULT_LAB_PROFILE="recommended"

INSTALL_WAIT_TIMEOUT_SECONDS=300
WEBHOOK_WAIT_TIMEOUT_SECONDS=120
PROXY_SYNC_WAIT_TIMEOUT_SECONDS=120

# Revision name this module installs Istiod under — even though only one
# revision is used in this phase, naming it explicitly (rather than the
# unnamed/default revision) keeps the install revision-upgrade-ready per
# docs/DECISIONS.md ADR-024.
ISTIO_REVISION="stable-1-30"

# Runtime test resources are labeled with this value and only ever
# created in DEMO_NAMESPACE/EXTERNAL_NAMESPACE or a namespace matching
# this prefix, so cleanup/verification scripts can always find (and
# only ever touch) resources this lab created.
LAB_RESOURCE_LABEL_KEY="app.kubernetes.io/part-of"
LAB_RESOURCE_LABEL_VALUE="istio-learning-lab"
TEMP_NAMESPACE_PREFIX="istio-lab-tmp-"

# --- Traffic generation defaults (scripts/generate-traffic.sh) --------
TRAFFIC_DEFAULT_REQUESTS=100
TRAFFIC_DEFAULT_CONCURRENCY=5
TRAFFIC_STATISTICAL_TOLERANCE_PERCENT=15

# --- Lab 15 (JWT) --------------------------------------------------------
# Locally-generated, short-lived test signing key — never a remote IdP
# dependency. Generated into ../.generated/jwt/ (git-ignored), never
# committed. See labs/lab-15-jwt-authentication.md.
JWT_TEST_ISSUER="https://istio-lab.local/test-issuer"
JWT_TEST_AUDIENCE="istio-lab-demo"
