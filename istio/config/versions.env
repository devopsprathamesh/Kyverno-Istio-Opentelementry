#!/usr/bin/env bash
# Single source of truth for every pinned version this module's scripts
# and Makefile use. See ../../docs/VERSIONS.md for sources, compatibility
# notes, and the research date. Never replace a value here with "latest".

# --- Istio ------------------------------------------------------------
ISTIO_VERSION="1.30.3"
ISTIOCTL_VERSION="1.30.3"
ISTIO_HELM_REPO="https://istio-release.storage.googleapis.com/charts"
ISTIO_HELM_REPO_NAME="istio"

# All four charts version-lock to the Istio release itself.
ISTIO_CHART_BASE_VERSION="1.30.3"
ISTIO_CHART_ISTIOD_VERSION="1.30.3"
ISTIO_CHART_CNI_VERSION="1.30.3"
ISTIO_CHART_GATEWAY_VERSION="1.30.3"

# Kubernetes versions this Istio release is officially tested against
# (istio.io/latest/docs/releases/supported-releases) — informational,
# used by verify-cluster.sh to warn (not fail) on a mismatch.
ISTIO_SUPPORTED_K8S_MIN="1.32"
ISTIO_SUPPORTED_K8S_MAX="1.36"

# --- Kubernetes Gateway API ------------------------------------------
# v1.4.0 deliberately, not the newer v1.6.1 — chosen for ecosystem/
# Istio-conformance maturity at research time. See docs/VERSIONS.md
# "Phase 4 addendum" for the full reasoning.
GATEWAY_API_VERSION="v1.4.0"
GATEWAY_API_CRDS_URL="https://github.com/kubernetes-sigs/gateway-api/releases/download/${GATEWAY_API_VERSION}/standard-install.yaml"

# --- Cilium CNI-chaining compatibility (informational; NOT applied by
# this module — see docs/04-istio-cni-and-cilium.md and
# scripts/check-prerequisites.sh) ------------------------------------
CILIUM_CNI_CHAINING_REQUIRED_VALUES="cni.exclusive=false,socketLB.hostNamespaceOnly=true"

# --- Demo application ---------------------------------------------------
# See docs/DECISIONS.md ADR-022-adjacent note (demo app design) —
# traefik/whoami used for every demo service rather than custom-built
# images, avoiding a local registry/build-pipeline dependency this repo
# does not have.
WHOAMI_IMAGE="traefik/whoami"
WHOAMI_IMAGE_TAG="v1.11.0"
