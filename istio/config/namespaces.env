#!/usr/bin/env bash
# Namespace configuration for this module. See
# ../docs/02-istio-architecture.md for what each namespace owns.

ISTIO_SYSTEM_NAMESPACE="istio-system"
ISTIO_INGRESS_NAMESPACE="istio-ingress"
DEMO_NAMESPACE="istio-demo"
EXTERNAL_NAMESPACE="istio-external"

# Namespaces this module is allowed to create/own. clean.sh/uninstall.sh
# use this list defensively — never delete a namespace not on this list.
OWNED_NAMESPACES="${ISTIO_SYSTEM_NAMESPACE} ${ISTIO_INGRESS_NAMESPACE} ${DEMO_NAMESPACE} ${EXTERNAL_NAMESPACE}"
