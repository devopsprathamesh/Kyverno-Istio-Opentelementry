#!/usr/bin/env bash
# Expected cluster identity (from ../../auto-setup-default-kube-env) and
# demo-application internal endpoints. verify-cluster.sh refuses to
# proceed if the live cluster doesn't match the values in this file.

EXPECTED_CLUSTER_NAME="devops-learning-lab"
EXPECTED_API_ENDPOINT="192.168.56.10"
EXPECTED_CONTROL_PLANE_NAME="otel-control-plane"
EXPECTED_WORKER1_NAME="otel-worker-1"
EXPECTED_WORKER2_NAME="otel-worker-2"

# --- Demo application service ports (all HTTP, all traefik/whoami) ------
FRONTEND_PORT=80
ORDER_SERVICE_PORT=80
INVENTORY_SERVICE_PORT=80
PAYMENT_SERVICE_PORT=80

# Ingress gateway local access — port-forwarded, never host-bound or
# publicly exposed by default. See docs/DECISIONS.md ADR-023.
INGRESS_GATEWAY_LOCAL_PORT=8080
INGRESS_GATEWAY_SERVICE_PORT=80

# Envoy admin interface — reachable only via `istioctl dashboard envoy`/
# `kubectl port-forward` to a specific pod, never exposed cluster-wide.
ENVOY_ADMIN_PORT=15000
