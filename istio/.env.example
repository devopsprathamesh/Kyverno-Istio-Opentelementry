# Copy to .env and source (`set -a; source .env; set +a`) before running
# `make`/`kubectl`/`istioctl` commands to override defaults without
# editing tracked files. .env is git-ignored (root .gitignore: ".env");
# this .example file is the only one tracked.

# --- Profile selection ----------------------------------------------------
# LAB_PROFILE=minimum

# --- Kubeconfig -------------------------------------------------------
# Point at the base platform's exported kubeconfig (see
# ../auto-setup-default-kube-env/docs/INSTALLATION.md):
# export KUBECONFIG=/absolute/path/to/auto-setup-default-kube-env/.generated/kubeconfig

# --- Destructive uninstall opt-in ----------------------------------------
# Only set when you specifically intend to delete every Istio CRD
# cluster-wide (see scripts/uninstall.sh's warning) — leave unset/false
# for normal use.
# REMOVE_CRDS=true

# See examples/profile-overrides.env.example for the full list of
# per-profile values (replica counts, resource requests) this lab's
# LAB_PROFILE switches between, and examples/application-access.md for
# how to reach the demo app and ingress gateway once installed.
