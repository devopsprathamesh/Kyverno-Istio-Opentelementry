# Copy to .env and source (`set -a; source .env; set +a`) before running
# `make`/`kubectl` commands to override defaults without editing tracked
# files. .env is git-ignored (root .gitignore: ".env"); this .example
# file is the only one tracked.

# --- Profile selection ----------------------------------------------------
# LAB_PROFILE=minimum

# --- Kubeconfig -------------------------------------------------------
# Point at the base platform's exported kubeconfig (see
# ../auto-setup-default-kube-env/docs/INSTALLATION.md):
# export KUBECONFIG=/absolute/path/to/auto-setup-default-kube-env/.generated/kubeconfig

# --- Optional lab-11 (image verification) Cosign runtime path -----------
# Off by default — see config/lab-settings.env and
# labs/lab-11-image-verification.md.
# ENABLE_COSIGN_RUNTIME_LAB=true

# --- Optional Policy Reporter install -------------------------------------
# Off by default — see install/optional/policy-reporter-values.yaml and
# README.md "Reports".
# ENABLE_POLICY_REPORTER=true

# --- Destructive uninstall opt-in ----------------------------------------
# Only set when you specifically intend to delete every Kyverno CRD
# cluster-wide (see scripts/uninstall.sh's warning) — leave unset/false
# for normal use.
# REMOVE_CRDS=true
