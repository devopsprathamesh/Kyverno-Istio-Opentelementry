#!/usr/bin/env bash
# General lab behavior settings — timeouts, optional-feature toggles, and
# defaults referenced by the Makefile and scripts/*.sh.

VALID_LAB_PROFILES="minimum recommended"
DEFAULT_LAB_PROFILE="recommended"

# How long scripts wait for Kyverno controllers/webhooks/reports to
# become ready before treating it as a failure.
INSTALL_WAIT_TIMEOUT_SECONDS=180
WEBHOOK_WAIT_TIMEOUT_SECONDS=120
REPORT_WAIT_TIMEOUT_SECONDS=60

# Runtime test resources are labeled with this value and only ever
# created in DEMO_NAMESPACE or a namespace matching this prefix, so
# cleanup/verification scripts can always find (and only ever touch)
# resources this lab created.
LAB_RESOURCE_LABEL_KEY="app.kubernetes.io/part-of"
LAB_RESOURCE_LABEL_VALUE="kyverno-learning-lab"
TEMP_NAMESPACE_PREFIX="kyverno-lab-tmp-"

# --- Optional lab-11 (image verification) Cosign runtime path -----------
# Off by default — lab 11's static/offline path (policy syntax +
# `kyverno apply` against documented public signed images) requires no
# opt-in. Set to "true" only if you have (or want this lab to generate)
# a local Cosign keypair for a live signed/unsigned image demo.
ENABLE_COSIGN_RUNTIME_LAB="false"
# Lab-generated keys, if the above is enabled, are written under
# ../.generated/cosign/ — git-ignored, never committed, cleaned by
# `make clean`.

# --- Optional Policy Reporter install -------------------------------------
# Off by default — this independent lab does not require Policy Reporter
# or any UI; `install/optional/policy-reporter-values.yaml` and its own
# make target exist for learners who want the extra visualization layer.
ENABLE_POLICY_REPORTER="false"
