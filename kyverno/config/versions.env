#!/usr/bin/env bash
# Single source of truth for every pinned version this module's scripts
# and Makefile use. See ../../docs/VERSIONS.md for sources, compatibility
# notes, and the research date. Never replace a value here with "latest".

# --- Kyverno --------------------------------------------------------------
KYVERNO_CHART_VERSION="3.8.2"
KYVERNO_APP_VERSION="v1.18.2"
KYVERNO_CHART_REPO="https://kyverno.github.io/kyverno/"
KYVERNO_HELM_REPO_NAME="kyverno"

# Kubernetes versions this Kyverno release is officially tested against
# (kyverno.io/docs/installation/releases) — informational, used by
# verify-cluster.sh to warn (not fail) if the live cluster's Kubernetes
# version falls outside this range.
KYVERNO_SUPPORTED_K8S_MIN="1.33"
KYVERNO_SUPPORTED_K8S_MAX="1.35"

# --- Kyverno CLI ------------------------------------------------------
# Released from the same kyverno/kyverno repo/tag as the application.
KYVERNO_CLI_VERSION="v1.18.2"
KYVERNO_CLI_RELEASE_BASE="https://github.com/kyverno/kyverno/releases/download/${KYVERNO_CLI_VERSION}"
# Exact release asset naming is re-confirmed at install time (see
# scripts/check-prerequisites.sh) rather than hardcoded here, since
# release asset filenames have changed across Kyverno's own release
# tooling versions.

# --- Policy Reporter (optional install only) -----------------------------
POLICY_REPORTER_CHART_VERSION="3.8.1"
POLICY_REPORTER_APP_VERSION="3.8.1"
POLICY_REPORTER_CHART_REPO="https://kyverno.github.io/policy-reporter/"
POLICY_REPORTER_HELM_REPO_NAME="policy-reporter"

# --- Base platform expectations (from auto-setup-default-kube-env) ------
# Used by verify-cluster.sh to confirm this is the intended local lab
# cluster before installing anything — never installs Kyverno into an
# unrecognized cluster.
EXPECTED_CLUSTER_NAME="devops-learning-lab"
EXPECTED_API_ENDPOINT="192.168.56.10"
EXPECTED_CONTROL_PLANE_NAME="otel-control-plane"
EXPECTED_WORKER1_NAME="otel-worker-1"
EXPECTED_WORKER2_NAME="otel-worker-2"
