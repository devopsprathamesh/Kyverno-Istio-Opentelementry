#!/usr/bin/env bash
# Namespace configuration: install target, demo target, and the default
# policy-exclusion list. See ../docs/14-troubleshooting.md and
# ../docs/12-security-and-governance.md for why broad exclusions weaken
# governance and should stay narrow and reviewed.

KYVERNO_NAMESPACE="kyverno"
DEMO_NAMESPACE="kyverno-demo"

# Namespaces excluded from policy enforcement by default, space-separated.
# "cilium" and "hubble" are included for completeness/future-proofing but
# are currently no-ops in this repository: Phase 2's auto-setup-default-
# kube-env installs Cilium/Hubble into kube-system (see
# auto-setup-default-kube-env/config/cluster.env CILIUM_NAMESPACE), which
# is already excluded — documented here rather than silently assumed.
DEFAULT_EXCLUDED_NAMESPACES="kube-system kube-public kube-node-lease kyverno cilium hubble"

# Deliberately NOT excluded by default (see docs/12-security-and-governance.md
# "Why broad exclusions weaken governance"): the kyverno-demo namespace
# itself (policies must actually apply to the thing you're using to learn
# them), any application/default namespace, and any ServiceAccount- or
# controller-scoped wildcard.
